# Copy this file to .env and replace values as needed.
MONGO_URI=mongodb+srv://<username>:<encoded_password>@lpu.amxxiyi.mongodb.net/?retryWrites=true&w=majority&authSource=admin
MONGO_DB_NAME=lpu_smart
MONGO_PERSISTENCE_REQUIRED=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=20000
MONGO_STARTUP_MAX_ATTEMPTS=6
MONGO_STARTUP_RETRY_DELAY_SECONDS=2.0
APP_ACCESS_COOKIE_NAME=lpu_access_token
APP_COOKIE_SECURE=false
ALLOW_DEMO_SEED=false
FACE_VERIFICATION_MODE=opencv_only
FACE_MATCH_PASS_THRESHOLD=0.78
FACE_MATCH_MIN_SIMILARITY=0.78
FACE_MATCH_MIN_FRAMES=5
FACE_MATCH_MAX_FRAMES=8
FACE_ANTI_SPOOF_BLUR_THRESHOLD=95
FACE_ANTI_SPOOF_MIN_FACE_AREA_RATIO=0.08
FACE_ANTI_SPOOF_MIN_EYE_DISTANCE_RATIO=0.18
FACE_ANTI_SPOOF_MIN_LOWER_TEXTURE_RATIO=0.26
FACE_ANTI_SPOOF_MIN_CONTRAST=18
FACE_FACE_CENTER_OFFSET_MAX_RATIO=0.34
FACE_LIVENESS_MIN_MOTION=0.028
FACE_LIVENESS_MIN_POSE_DELTA=0.02
FACE_LIVENESS_MIN_TEXTURE_JITTER=0.012
FACE_LIVENESS_MIN_CONTRAST_JITTER=0.9

# Razorpay settings
RAZORPAY_KEY_ID=YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

# OTP delivery mode: smtp, graph, or debug (development only)
OTP_DELIVERY_MODE=smtp

# SMTP mode
OTP_SMTP_HOST=smtp.gmail.com
OTP_SMTP_PORT=587
OTP_SMTP_USERNAME=your_sender_gmail@gmail.com
OTP_SMTP_PASSWORD=your_gmail_app_password
OTP_SMTP_STARTTLS=true
OTP_SMTP_USE_SSL=false
OTP_FROM_EMAIL=your_sender_gmail@gmail.com
OTP_SUBJECT_PREFIX=LPU Smart Campus

# Microsoft Graph mode (recommended if SMTP AUTH is blocked by policy)
OTP_GRAPH_TENANT_ID=
OTP_GRAPH_CLIENT_ID=
OTP_GRAPH_CLIENT_SECRET=
OTP_GRAPH_SENDER_USER=your_sender_email
