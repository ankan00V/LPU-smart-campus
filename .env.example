# Managed production template.
# For local-only development, use .env.local.example instead.
# For Neon or another PgBouncer-backed provider, use the pooled endpoint for the app
# and the direct endpoint for admin tools / dumps / TablePlus.
SQLALCHEMY_DATABASE_URL=postgresql+psycopg://smartcampus:<encoded_password>@ep-<id>-pooler.<region>.aws.neon.tech/lpu_smart?sslmode=require
POSTGRES_ADMIN_DATABASE_URL=postgresql+psycopg://smartcampus:<encoded_password>@ep-<id>.<region>.aws.neon.tech/lpu_smart?sslmode=require
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_SSL_MODE=require
DATABASE_DISABLE_PREPARED_STATEMENTS=true
DATABASE_SSL_ROOT_CERT=
DATABASE_SSL_CERT=
DATABASE_SSL_KEY=
DATABASE_APPLICATION_NAME=lpu-smart-campus-api
DATABASE_STATEMENT_TIMEOUT_MS=15000

MONGO_URI=mongodb+srv://<username>:<encoded_password>@lpu.amxxiyi.mongodb.net/?retryWrites=true&w=majority&authSource=admin
# Optional fallback when SRV DNS is unstable.
# Use replica hostnames, not raw IPs, so TLS/SNI still works.
# Example format:
# MONGO_URI_FALLBACK=mongodb://<username>:<encoded_password>@<host1>.<cluster>.mongodb.net:27017,<host2>.<cluster>.mongodb.net:27017,<host3>.<cluster>.mongodb.net:27017/?authSource=admin&replicaSet=<replica_set_name>&retryWrites=true&w=majority&tls=true
MONGO_DB_NAME=lpu_smart
MONGO_PERSISTENCE_REQUIRED=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=20000
MONGO_DNS_NAMESERVERS=1.1.1.1,8.8.8.8
MONGO_DNS_LIFETIME_SECONDS=10
MONGO_DNS_TIMEOUT_SECONDS=5
MONGO_STARTUP_MAX_ATTEMPTS=6
MONGO_STARTUP_RETRY_DELAY_SECONDS=2.0
MONGO_STARTUP_STRICT=true
# Keep startup fast; run scripts/sync_relational_to_mongo_snapshot.py after cutover/backfill.
MONGO_STARTUP_SQL_SNAPSHOT_SYNC=false
MONGO_READ_PREFERRED=true
MONGO_TLS_CA_FILE=
APP_RUNTIME_STRICT=true
APP_MANAGED_SERVICES_REQUIRED=true
APP_ACCESS_COOKIE_NAME=lpu_access_token
APP_COOKIE_SECURE=true
ALLOW_DEMO_SEED=false
FACE_VERIFICATION_MODE=opencv_only
FACE_VERIFICATION_PROVIDER=auto
FACE_DNN_AUTO_DOWNLOAD=true
FACE_MODEL_CACHE_DIR=.model_cache/opencv
FACE_DNN_DETECTION_SCORE_THRESHOLD=0.88
IDENTITY_ENROLLMENT_FACE_MATCH_MIN=0.72
IDENTITY_ENROLLMENT_FACE_MATCH_WARN=0.82
FACE_MATCH_PASS_THRESHOLD=0.78
FACE_MATCH_MIN_SIMILARITY=0.78
FACE_MATCH_MIN_FRAMES=5
FACE_MATCH_MAX_FRAMES=8
FACE_ANTI_SPOOF_BLUR_THRESHOLD=95
FACE_ANTI_SPOOF_MIN_FACE_AREA_RATIO=0.08
FACE_ANTI_SPOOF_MIN_EYE_DISTANCE_RATIO=0.18
FACE_ANTI_SPOOF_MIN_LOWER_TEXTURE_RATIO=0.26
FACE_ANTI_SPOOF_MIN_CONTRAST=18
FACE_FACE_CENTER_OFFSET_MAX_RATIO=0.34
FACE_LIVENESS_MIN_MOTION=0.028
FACE_LIVENESS_MIN_POSE_DELTA=0.02
FACE_LIVENESS_MIN_TEXTURE_JITTER=0.012
FACE_LIVENESS_MIN_CONTRAST_JITTER=0.9

# Attendance Recovery Autopilot
ATTENDANCE_RECOVERY_ENABLED=true
ATTENDANCE_RECOVERY_PARENT_ALERTS_ENABLED=true
ATTENDANCE_RECOVERY_WATCH_THRESHOLD=75
ATTENDANCE_RECOVERY_HIGH_THRESHOLD=65
ATTENDANCE_RECOVERY_CRITICAL_THRESHOLD=50
ATTENDANCE_RECOVERY_DUE_DAYS=5
ATTENDANCE_RECOVERY_WATCH_CONSECUTIVE_ABSENCES=2
ATTENDANCE_RECOVERY_HIGH_CONSECUTIVE_ABSENCES=3
ATTENDANCE_RECOVERY_CRITICAL_CONSECUTIVE_ABSENCES=4
ATTENDANCE_RECOVERY_MIN_DELIVERED_CLASSES=2

# Saarthi AI counselling
SAARTHI_LLM_PROVIDER=gemini
SAARTHI_LLM_MODEL=gemini-2.5-flash
SAARTHI_LLM_REQUIRED=true
SAARTHI_LLM_TIMEOUT_SECONDS=20
# Optional OpenRouter-specific model id. Defaults to provider-prefixed form of SAARTHI_LLM_MODEL.
SAARTHI_OPENROUTER_MODEL=google/gemini-2.5-flash
GEMINI_API_KEY=
# Optional key rotation pool (JSON object: {"v1":"key","v2":"key"})
GEMINI_API_KEYRING_JSON={}
GEMINI_ACTIVE_KEY_ID=
OPENROUTER_API_KEY=
OPENROUTER_API_KEYRING_JSON={}
OPENROUTER_ACTIVE_KEY_ID=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Razorpay settings
RAZORPAY_KEY_ID=YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET
# Optional active-key rotation pool (JSON object: {"v1":{"key_id":"...","key_secret":"..."}})
RAZORPAY_KEYRING_JSON={}
RAZORPAY_ACTIVE_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_WEBHOOK_SECRETS_JSON={}
RAZORPAY_WEBHOOK_ACTIVE_SECRET_ID=
FOOD_PAYMENT_WEBHOOK_TOKEN=

# OTP delivery mode: smtp or graph only
OTP_DELIVERY_MODE=smtp
OTP_VERIFY_CONNECTION_ON_STARTUP=true

# SMTP mode
OTP_SMTP_HOST=smtp.gmail.com
OTP_SMTP_PORT=587
OTP_SMTP_USERNAME=your_sender_gmail@gmail.com
OTP_SMTP_PASSWORD=your_gmail_app_password
OTP_SMTP_STARTTLS=true
OTP_SMTP_USE_SSL=false
OTP_FROM_EMAIL=your_sender_gmail@gmail.com
OTP_SUBJECT_PREFIX=LPU Smart Campus

# Microsoft Graph mode (recommended if SMTP AUTH is blocked by policy)
OTP_GRAPH_TENANT_ID=
OTP_GRAPH_CLIENT_ID=
OTP_GRAPH_CLIENT_SECRET=
OTP_GRAPH_SENDER_USER=your_sender_email

# Redis / distributed runtime services
REDIS_URL=rediss://default:<encoded_password>@cache.<provider>.com:6379/0
REDIS_REQUIRED=true
REDIS_SSL_REQUIRED=true
REDIS_SOCKET_TIMEOUT_SECONDS=1.5
REDIS_SSL_CA_FILE=
REDIS_SSL_CERT_FILE=
REDIS_SSL_KEY_FILE=
REDIS_SSL_CHECK_HOSTNAME=true
REDIS_SSL_CERT_REQS=required
REALTIME_REDIS_CHANNEL=campus:events:stream

# Global API rate limiting (strict Redis-backed)
API_RATE_LIMIT_DEFAULT=120
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_IP_DEFAULT=240
API_RATE_LIMIT_USER_DEFAULT=160
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_EXEMPT_PATHS=/docs,/redoc,/openapi.json,/metrics,/web,/ui,/assets/static,/assets/media,/favicon.ico,/apple-touch-icon.png,/apple-touch-icon-precomposed.png
API_MAX_BODY_BYTES=8388608
API_MAX_PATH_LENGTH=1024
API_MAX_QUERY_KEY_LENGTH=80
API_MAX_QUERY_VALUE_LENGTH=400

# Worker backend (Celery optional)
# Some managed Redis providers, including Upstash, only support DB 0. In that case,
# reuse /0 for REDIS_URL, CELERY_BROKER_URL, and CELERY_RESULT_BACKEND.
CELERY_BROKER_URL=rediss://default:<encoded_password>@cache.<provider>.com:6379/1
CELERY_RESULT_BACKEND=rediss://default:<encoded_password>@cache.<provider>.com:6379/2
WORKER_REQUIRED=true
WORKER_ENABLE_OTP=true
WORKER_ENABLE_NOTIFICATIONS=true
WORKER_ENABLE_FACE_REVERIFY=true
WORKER_ENABLE_RECOMPUTE=true
WORKER_WAIT_FOR_OTP_RESULT=true
WORKER_TASK_TIME_LIMIT_SECONDS=60
WORKER_INLINE_FALLBACK_ENABLED=false
WORKER_STARTUP_MAX_ATTEMPTS=4
WORKER_STARTUP_RETRY_DELAY_SECONDS=1.0
WORKER_STARTUP_PING_TIMEOUT_SECONDS=2.0

# Observability
LOG_LEVEL=INFO
ERROR_BUDGET_TARGET=0.995
ERROR_BUDGET_WINDOW_SECONDS=3600
ADMIN_LIVE_CACHE_TTL_SECONDS=8
ADMIN_INSIGHTS_CACHE_TTL_SECONDS=15

# Enterprise controls
APP_ENV=production
APP_SECRETS_PROVIDER=file
APP_SECRETS_FILE=
APP_AWS_SECRET_ID=
APP_AWS_REGION=ap-south-1
APP_AUTH_SECRET=change-me
SCIM_BEARER_TOKEN=change-me
APP_LOOKUP_HASH_SECRET=change-me
APP_FIELD_ENCRYPTION_REQUIRED=true
APP_FIELD_ENCRYPTION_PRIMARY_KEY=
APP_FIELD_ENCRYPTION_KEYS_JSON={}
APP_FIELD_ENCRYPTION_ACTIVE_KEY_ID=
APP_ENFORCE_PRIVILEGED_MFA=true
MFA_ISSUER_NAME=LPU Smart Campus
MFA_TOTP_LOGIN_DRIFT_STEPS=4
MFA_TOTP_ACTIVATION_DRIFT_STEPS=10

# SSO / SCIM mapping (JSON)
SSO_PROVIDER_TENANTS_JSON={}
SSO_TENANT_ALLOWED_DOMAINS_JSON={}
SCIM_GROUP_ROLE_MAP_JSON={}

# Example IdP provider keys (provider token in uppercase, e.g. OKTA, AZUREAD)
# SSO_OIDC_OKTA_HS256_SECRET=
# SSO_OIDC_OKTA_ISSUER=https://idp.example.com/oauth2/default
# SSO_OIDC_OKTA_AUDIENCE=campus-app
# SSO_SAML_OKTA_SIGNING_SECRET=

# Compliance and deletion governance
APP_RETENTION_POLICIES_DAYS_JSON={}
APP_AUDIT_EXPORT_MAX_DOCS=100000
APP_EVIDENCE_SLA_WINDOW_MINUTES=60
APP_DELETION_DUAL_CONTROL_REQUIRED=true

# Capacity planning
APP_SLA_TARGETS_MS_JSON={}
APP_CAPACITY_BASELINE_RPS=0
APP_CAPACITY_PER_NODE_RPS=25
APP_CAPACITY_CURRENT_NODES=1
APP_AUTOSCALE_UP_THRESHOLD_PERCENT=75
APP_AUTOSCALE_DOWN_THRESHOLD_PERCENT=30

# DR offsite replication
DR_OFFSITE_PATH=
