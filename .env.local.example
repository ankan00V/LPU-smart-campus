# Local development template.
# This keeps strict runtime enabled while allowing local services.

SQLALCHEMY_DATABASE_URL=postgresql+psycopg://smartcampus:change-me@127.0.0.1:5432/lpu_smart
POSTGRES_ADMIN_DATABASE_URL=postgresql+psycopg://smartcampus:change-me@127.0.0.1:5432/lpu_smart
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT_SECONDS=30
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_SSL_MODE=disable
DATABASE_DISABLE_PREPARED_STATEMENTS=false
DATABASE_APPLICATION_NAME=lpu-smart-campus-local

MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=lpu_smart
MONGO_PERSISTENCE_REQUIRED=true
MONGO_SERVER_SELECTION_TIMEOUT_MS=15000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=20000
MONGO_DNS_NAMESERVERS=1.1.1.1,8.8.8.8
MONGO_DNS_LIFETIME_SECONDS=10
MONGO_DNS_TIMEOUT_SECONDS=5
MONGO_STARTUP_MAX_ATTEMPTS=6
MONGO_STARTUP_RETRY_DELAY_SECONDS=2.0
MONGO_STARTUP_STRICT=true
MONGO_STARTUP_SQL_SNAPSHOT_SYNC=false
MONGO_READ_PREFERRED=true

APP_RUNTIME_STRICT=true
APP_MANAGED_SERVICES_REQUIRED=false
APP_ACCESS_COOKIE_NAME=lpu_access_token
APP_COOKIE_SECURE=false
ALLOW_DEMO_SEED=false

OTP_DELIVERY_MODE=smtp
OTP_SMTP_HOST=smtp.gmail.com
OTP_SMTP_PORT=587
OTP_SMTP_USERNAME=your_sender_gmail@gmail.com
OTP_SMTP_PASSWORD=your_gmail_app_password
OTP_SMTP_STARTTLS=true
OTP_SMTP_USE_SSL=false
OTP_FROM_EMAIL=your_sender_gmail@gmail.com
OTP_SUBJECT_PREFIX=LPU Smart Campus

RAZORPAY_KEY_ID=YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET

REDIS_URL=redis://127.0.0.1:6379/0
REDIS_REQUIRED=true
REDIS_SSL_REQUIRED=false
REDIS_SOCKET_TIMEOUT_SECONDS=1.5
REALTIME_REDIS_CHANNEL=campus:events:stream

API_RATE_LIMIT_DEFAULT=120
API_RATE_LIMIT_WINDOW_SECONDS=60

FACE_VERIFICATION_PROVIDER=auto
FACE_DNN_AUTO_DOWNLOAD=true
FACE_MODEL_CACHE_DIR=.model_cache/opencv
FACE_DNN_DETECTION_SCORE_THRESHOLD=0.88
IDENTITY_ENROLLMENT_FACE_MATCH_MIN=0.72
IDENTITY_ENROLLMENT_FACE_MATCH_WARN=0.82

ATTENDANCE_RECOVERY_ENABLED=true
ATTENDANCE_RECOVERY_PARENT_ALERTS_ENABLED=true
ATTENDANCE_RECOVERY_WATCH_THRESHOLD=75
ATTENDANCE_RECOVERY_HIGH_THRESHOLD=65
ATTENDANCE_RECOVERY_CRITICAL_THRESHOLD=50
ATTENDANCE_RECOVERY_DUE_DAYS=5
ATTENDANCE_RECOVERY_WATCH_CONSECUTIVE_ABSENCES=2
ATTENDANCE_RECOVERY_HIGH_CONSECUTIVE_ABSENCES=3
ATTENDANCE_RECOVERY_CRITICAL_CONSECUTIVE_ABSENCES=4
ATTENDANCE_RECOVERY_MIN_DELIVERED_CLASSES=2

SAARTHI_LLM_PROVIDER=gemini
SAARTHI_LLM_MODEL=gemini-2.5-flash
SAARTHI_LLM_REQUIRED=false
SAARTHI_LLM_TIMEOUT_SECONDS=20
GEMINI_API_KEYS_JSON=[]
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OPENROUTER_API_KEY=
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://127.0.0.1:8000
OPENROUTER_APP_NAME=LPU Smart Campus Saarthi

APP_INTERNAL_SCHEDULER_ENABLED=true
APP_INTERNAL_SCHEDULER_POLL_SECONDS=30
APP_INTERNAL_SCHEDULER_INITIAL_DELAY_SECONDS=15
APP_INTERNAL_SCHEDULER_LEASE_SECONDS=900
APP_INTERNAL_SCHEDULER_FAILURE_RETRY_SECONDS=300
APP_INTERNAL_SCHEDULER_TIMEZONE=Asia/Kolkata
APP_INTERNAL_SCHEDULER_SAARTHI_SWEEP_INTERVAL_SECONDS=3600

CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2
WORKER_REQUIRED=true
WORKER_ENABLE_OTP=true
WORKER_ENABLE_NOTIFICATIONS=true
WORKER_ENABLE_FACE_REVERIFY=true
WORKER_ENABLE_RECOMPUTE=true
WORKER_WAIT_FOR_OTP_RESULT=true
WORKER_TASK_TIME_LIMIT_SECONDS=60
WORKER_INLINE_FALLBACK_ENABLED=false

LOG_LEVEL=INFO
APP_ENV=development
APP_SECRETS_PROVIDER=env
APP_AUTH_SECRET=change-me
SCIM_BEARER_TOKEN=change-me
APP_LOOKUP_HASH_SECRET=change-me
APP_FIELD_ENCRYPTION_REQUIRED=false
APP_FIELD_ENCRYPTION_PRIMARY_KEY=
APP_FIELD_ENCRYPTION_KEYS_JSON={}
APP_FIELD_ENCRYPTION_ACTIVE_KEY_ID=
